{
  "manifest_version": 3,
  "name": "UrbSync - Extrator de Processos",
  "description": "Automatize a extração de dados do Aprova Digital e SEI. Exporte processos para Excel com um único clique.",
  "version": "1.0",
  "icons": {
    "16": "src/assets/images/icon16.png",
    "48": "src/assets/images/icon48.png",
    "128": "src/assets/images/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://sei.prefeitura.sp.gov.br/*",
    "https://portaldolicenciamentosp.com.br/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "src/assets/images/icon16.png",
      "48": "src/assets/images/icon48.png",
      "128": "src/assets/images/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/content/core/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sei.prefeitura.sp.gov.br/sei/*",
        "https://portaldolicenciamentosp.com.br/*"
      ],
      "js": [
        "vendor/exceljs.min.js",
        "src/content/core/loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/**/*", "vendor/*"],
      "matches": [
        "https://sei.prefeitura.sp.gov.br/*",
        "https://portaldolicenciamentosp.com.br/*"
      ]
    }
  ]
}
